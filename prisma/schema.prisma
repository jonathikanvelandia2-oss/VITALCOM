// Vitalcom — Schema Prisma inicial
// Multi-rol + Multi-país (CO/EC/GT/CL)
// Ver CLAUDE.md sección "Schema de base de datos" para contexto completo

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum UserRole {
  SUPERADMIN
  ADMIN
  MANAGER_AREA
  EMPLOYEE
  COMMUNITY
  DROPSHIPPER
}

enum Country {
  CO
  EC
  GT
  CL
}

enum Area {
  DIRECCION       // CEO — acceso total
  MARKETING       // Campañas, contenido, comunidad
  COMERCIAL       // Ventas, clientes, catálogo
  ADMINISTRATIVA  // Operaciones, RRHH, procesos
  LOGISTICA       // Stock, despachos, fulfillment Dropi
  CONTABILIDAD    // Finanzas, facturación, liquidaciones
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
  RETURNED
}

enum OrderSource {
  DIRECT
  ZENDU
  COMMUNITY
  DROPSHIPPER
}

// ─── FINANZAS (P&L del dropshipper) ───
enum FinanceType {
  INGRESO
  EGRESO
}

enum FinanceCategory {
  VENTA               // Ingreso por venta de orden
  COSTO_PRODUCTO      // COGS (costo directo del producto)
  ENVIO               // Costo de envío al cliente
  PUBLICIDAD          // Meta, TikTok, Google ads
  COMISION_PLATAFORMA // Shopify, pasarela, Vitalcom
  DEVOLUCION          // Reembolso o devolución
  EMPAQUE             // Material de empaque
  OPERATIVO           // Gastos operativos (internet, software)
  IMPUESTO            // IVA, retenciones
  OTRO                // Catch-all manual
}

enum FinanceSource {
  MANUAL          // Registrado por el usuario
  ORDER_REVENUE   // Auto-generado al entregar orden
  ORDER_COGS      // Auto-generado al entregar orden
  ORDER_SHIPPING  // Auto-generado al entregar orden
  ORDER_RETURN    // Auto-generado al devolver orden
  AD_SPEND        // Importado de Meta/TikTok/Google (Fase V2)
  SYSTEM          // Otro auto
}

// ─────────────────────────────────────────────────────────
// USUARIOS Y AUTH
// ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          UserRole  @default(COMMUNITY)
  country       Country?
  area          Area?
  avatar        String?
  phone         String?
  whatsapp      String?

  // Comunidad / gamificación
  level         Int       @default(1)
  points        Int       @default(0)
  bio           String?

  // Estado
  active        Boolean   @default(true)
  verified      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  posts            Post[]
  comments         Comment[]
  inboxSent        InboxMessage[]      @relation("MessageSender")
  inboxReceived    InboxMessage[]      @relation("MessageReceiver")
  orders           Order[]
  pricingCalcs     PricingCalculation[]
  workflows        WorkflowTemplate[]
  courseProgress    CourseProgress[]
  shopifyStores    ShopifyStore[]
  tasks            Task[]
  meetings         Meeting[]
  uploadedDocs     Document[]          @relation("UploadedDocs")
  financeEntries   FinanceEntry[]
  notifications    Notification[]
  conversationsA   Conversation[]      @relation("ConversationUserA")
  conversationsB   Conversation[]      @relation("ConversationUserB")
  directMessages   DirectMessage[]     @relation("DirectMessageSender")
  workflowActivations UserWorkflowActivation[]
  adAccounts       AdAccount[]
  campaignDrafts   CampaignDraft[]
  campaignRecommendations CampaignRecommendation[]
  adCreatives      AdCreative[]
  storeOptimizations StoreOptimization[]
  appliedActions   AppliedAction[]
}

// ─────────────────────────────────────────────────────────
// CATÁLOGO
// ─────────────────────────────────────────────────────────

model Product {
  id               String      @id @default(cuid())
  sku              String      @unique
  name             String
  slug             String      @unique
  description      String?
  category         String?
  subcategory      String?
  tags             String[]
  images           String[]
  // 8 niveles de precio Vitalcom (COP)
  precioPublico    Float       // Precio consumidor final
  precioComunidad  Float       // Precio miembros / dropshippers
  precioPrivado    Float       // Precio VIP
  // Internos (solo admin)
  precioCosto          Float?  // Costo de compra
  precioMayorProv      Float?  // Mayor proveeduría
  precioMayorContado   Float?  // Mayor contado
  precioMayorCredito   Float?  // Mayor crédito
  precioMaquilla       Float?  // Precio maquila

  // Datos extendidos del catálogo
  marca            String?     // Marca del producto
  contenido        String?     // "60U", "500ML", "1200G"
  presentacion     String?     // Capsulas, Liquido, Polvos, etc.
  sabor            String?     // Natural, Uva, Fresa, etc.
  bodega           String?     // BIOBEL, VITALCOM
  codigoInterno    String?     // Código original de la base
  pertenece        String?     // Dueño/influencer (para maquilas)
  weight           Float?
  dimensions       Json?
  active           Boolean     @default(true)
  bestseller       Boolean     @default(false)
  salesCount       Int         @default(0)

  // Landing page del producto
  videoUrl         String?              // Video parallax (Cloudinary URL)
  ingredients      Json?                // [{name, description, icon}]
  benefits         Json?                // [{title, description, icon}]
  howToUse         String?              // Instrucciones de uso
  testimonials     Json?                // [{name, text, rating, photo}]
  landingConfig    Json?                // {heroText, ctaText, accentColor, sections[]}

  stock            Stock[]
  orderItems       OrderItem[]
  shopifySync      ProductSync[]
  campaignDrafts   CampaignDraft[]
  adCreatives      AdCreative[]
  storeOptimizations StoreOptimization[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Stock {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  country    Country
  quantity   Int      @default(0)
  warehouse  String?
  updatedAt  DateTime @updatedAt

  @@unique([productId, country])
}

// ─────────────────────────────────────────────────────────
// PEDIDOS
// ─────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  number          String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  source          OrderSource
  country         Country
  status          OrderStatus @default(PENDING)

  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress String?

  items           OrderItem[]
  subtotal        Float
  shipping        Float
  total           Float

  trackingCode    String?
  carrier         String?
  notes           String?
  externalRef     String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([status, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  total     Float

  @@index([productId])
  @@index([orderId])
}

// ─────────────────────────────────────────────────────────
// INBOX INTERNO (entre áreas)
// ─────────────────────────────────────────────────────────

model InboxThread {
  id        String         @id @default(cuid())
  subject   String
  area      Area
  priority  String         @default("normal")
  resolved  Boolean        @default(false)
  messages  InboxMessage[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model InboxMessage {
  id          String      @id @default(cuid())
  threadId    String
  thread      InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User        @relation("MessageSender", fields: [senderId], references: [id])
  receiverId  String?
  receiver    User?       @relation("MessageReceiver", fields: [receiverId], references: [id])
  body        String
  attachments String[]
  read        Boolean     @default(false)
  createdAt   DateTime    @default(now())
}

// ─────────────────────────────────────────────────────────
// COMUNIDAD (estilo Skool)
// ─────────────────────────────────────────────────────────

model Post {
  id        String     @id @default(cuid())
  authorId  String
  author    User       @relation(fields: [authorId], references: [id])
  title     String?
  body      String
  images    String[]
  category  String?
  pinned    Boolean    @default(false)
  likes     Int        @default(0)
  postLikes PostLike[]
  comments  Comment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  parentId  String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())
}

model Course {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  description String?
  cover       String?
  level       String
  modules     Json
  published   Boolean          @default(false)
  order       Int              @default(0)
  progress    CourseProgress[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CourseProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  completedLessons String[]
  percentage  Int      @default(0)
  completed   Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([userId, courseId])
}

// ─────────────────────────────────────────────────────────
// HERRAMIENTAS DE COMUNIDAD
// ─────────────────────────────────────────────────────────

model PricingCalculation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  productName String
  basePrice   Float
  shipping    Float
  margin      Float
  finalPrice  Float
  country     Country
  notes       String?
  createdAt   DateTime @default(now())
}

model WorkflowTemplate {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  slug        String?  @unique             // Identificador legible para plantillas oficiales (ej: confirm-order)
  name        String
  description String?
  emoji       String?
  category    String
  target      String?                       // Audiencia del flujo (Nuevos pedidos, Leads, etc.)
  impact      String?                       // Etiqueta de resultado esperado
  steps       Json
  isPublic    Boolean  @default(false)
  uses        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activations UserWorkflowActivation[]
}

enum WorkflowStatus {
  ACTIVE
  PAUSED
}

model UserWorkflowActivation {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId  String
  template    WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  status      WorkflowStatus @default(ACTIVE)
  executions  Int            @default(0)
  successCount Int           @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, templateId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────
// INTEGRACIÓN SHOPIFY
// ─────────────────────────────────────────────────────────

model ShopifyStore {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  shopDomain      String    @unique   // mi-tienda.myshopify.com
  storeName       String
  accessToken     String?              // Token cifrado de Shopify API
  status          String    @default("not_connected")
  plan            String?
  productsCount   Int       @default(0)
  connectedAt     DateTime?
  lastSyncAt      DateTime?
  syncedProducts  ProductSync[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ProductSync {
  id                 String    @id @default(cuid())
  shopifyStoreId     String
  store              ShopifyStore @relation(fields: [shopifyStoreId], references: [id], onDelete: Cascade)
  productId          String
  product            Product   @relation(fields: [productId], references: [id])
  shopifyProductId   String
  shopifyVariantId   String?
  sellingPrice       Float     // Precio que el dropshipper puso en Shopify
  status             String    @default("active")
  soldTotal          Int       @default(0)
  lastSyncAt         DateTime  @default(now())
  createdAt          DateTime  @default(now())

  @@unique([shopifyStoreId, productId])
}

// ─────────────────────────────────────────────────────────
// TAREAS, REUNIONES, RECURSOS (Comunidad)
// ─────────────────────────────────────────────────────────

model Task {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String?
  status      String   @default("pending") // pending, in_progress, completed
  priority    String   @default("medium")  // low, medium, high
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Meeting {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  title        String
  description  String?
  date         DateTime
  duration     Int      @default(60) // minutos
  link         String?               // URL de meet/zoom
  type         String   @default("videocall") // videocall, presencial
  status       String   @default("scheduled") // scheduled, completed, cancelled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String                    // guias, plantillas, videos, ebooks
  type        String   @default("file") // file, link, video
  url         String                    // URL del archivo o enlace
  thumbnail   String?
  downloads   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id          String   @id @default(cuid())
  name        String
  folder      String   @default("general") // general, legal, marketing, logistica
  type        String                       // pdf, excel, doc, imagen
  url         String
  size        Int      @default(0)          // bytes
  uploadedBy  String
  uploader    User     @relation("UploadedDocs", fields: [uploadedBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// TOKENS DE SEGURIDAD
// ─────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────
// FINANZAS DEL DROPSHIPPER (P&L)
// ─────────────────────────────────────────────────────────
// Cada movimiento financiero del dropshipper. Combina entradas
// automáticas (ventas, COGS, envío) generadas al cerrar órdenes +
// entradas manuales (publicidad, empaque, operativo).
// El P&L se calcula agregando por periodo, tipo y categoría.

model FinanceEntry {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime         @default(now())
  type           FinanceType
  category       FinanceCategory
  amount         Float             // Siempre positivo; el tipo indica signo
  currency       String           @default("COP")
  description    String?
  source         FinanceSource    @default(MANUAL)

  // Referencias opcionales para rastrear origen
  relatedOrderId    String?
  relatedProductId  String?
  metadata          Json?         // Flexible: platformId, campaignId, adId (fase V2+)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId, date])
  @@index([userId, type, category])
  @@index([relatedOrderId])
}

// ─────────────────────────────────────────────────────────
// PUBLICIDAD (Meta / TikTok / Google Ads / Manual)
// ─────────────────────────────────────────────────────────
// Fase V2 del plan estratégico. Foundation que funciona con
// entrada manual hoy y queda lista para OAuth cuando lleguen
// credenciales.
//
// Cada AdSpendEntry genera automáticamente un FinanceEntry
// (EGRESO/PUBLICIDAD) para alimentar el P&G del dropshipper.

enum AdPlatform {
  META
  TIKTOK
  GOOGLE
  OTHER              // Prensa, influencers, OOH — gastos no digitales
}

model AdAccount {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    AdPlatform
  accountId   String                           // ID externo (Meta/TikTok/Google) o label libre
  accountName String?
  currency    String     @default("COP")
  connected   Boolean    @default(false)       // false = manual, true = OAuth conectado
  accessToken String?                          // Cuando llegue OAuth real
  refreshToken String?
  tokenExpiresAt DateTime?
  lastSyncAt  DateTime?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  campaigns       AdCampaign[]
  spendEntries    AdSpendEntry[]
  recommendations CampaignRecommendation[]

  @@unique([userId, platform, accountId])
  @@index([userId])
}

model AdCampaign {
  id          String     @id @default(cuid())
  accountId   String
  account     AdAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalId  String?                         // ID en la plataforma (cuando OAuth)
  name        String
  objective   String?                         // CONVERSIONS, TRAFFIC, AWARENESS, LEADS
  status      String     @default("ACTIVE")   // ACTIVE, PAUSED, ENDED
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  spendEntries    AdSpendEntry[]
  recommendations CampaignRecommendation[]

  @@index([accountId])
}

model AdSpendEntry {
  id             String     @id @default(cuid())
  accountId      String
  account        AdAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaignId     String?
  campaign       AdCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  date           DateTime   @db.Date
  spend          Float                         // Gasto en la moneda de la cuenta
  impressions    Int?
  clicks         Int?
  conversions    Int?
  source         String     @default("MANUAL") // MANUAL, API_SYNC
  financeEntryId String?    @unique            // Link al FinanceEntry auto-generado
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([accountId, date])
  @@index([campaignId, date])
}

// ─────────────────────────────────────────────────────────
// NOTIFICACIONES (in-app bell)
// ─────────────────────────────────────────────────────────
// Centraliza avisos al usuario: cambios de estado de pedido,
// menciones en comunidad, hilos de inbox asignados, etc.
// Para emails transaccionales, el envío se hace además desde
// el disparador del evento — este modelo es solo para el bell.

enum NotificationType {
  ORDER_STATUS      // Pedido cambió de estado (DISPATCHED / DELIVERED / etc.)
  ORDER_NEW         // Nuevo pedido recibido (staff)
  INBOX_MESSAGE     // Mensaje nuevo en hilo del inbox
  INBOX_ASSIGNED    // Hilo reasignado a tu área
  COMMUNITY_LIKE    // Like a tu post/comentario
  COMMUNITY_REPLY   // Respuesta a tu comentario
  COMMUNITY_DM      // Mensaje directo 1:1 en comunidad
  STORE_CONNECTED   // Tienda Shopify conectada
  AI_ACTION         // V20 — Acción IA crítica del Command Center
  SYSTEM            // Anuncios de plataforma
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?          // Ruta interna para redirigir al hacer click
  meta      Json?            // Payload adicional (orderNumber, threadId, etc.)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────
// CHAT 1:1 COMUNIDAD (mensajes directos entre miembros)
// ─────────────────────────────────────────────────────────
// Conversation es el "hilo" entre dos usuarios. Para garantizar
// unicidad, guardamos (userAId, userBId) en orden lexicográfico
// — eso hace el índice único determinístico sin importar quién inicia.

model Conversation {
  id            String           @id @default(cuid())
  userAId       String
  userA         User             @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId       String
  userB         User             @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime         @default(now())
  lastPreview   String?          // Últimos ~120 chars para la lista
  unreadForA    Int              @default(0)
  unreadForB    Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  messages      DirectMessage[]

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
}

model DirectMessage {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User          @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  readAt         DateTime?     // Timestamp cuando el otro participante lo leyó
  createdAt      DateTime      @default(now())

  @@index([conversationId, createdAt])
}

// ─────────────────────────────────────────────────────────
// EVENTOS
// ─────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  link        String?              // URL de meet/zoom/teams
  type        String   @default("webinar") // webinar, live, meetup, workshop
  speaker     String?
  cover       String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// WIZARD LANZADOR DE CAMPAÑAS (V15 / V3 plan)
// ─────────────────────────────────────────────────────────
// CampaignDraft guarda el estado del wizard de 5 pasos.
// Queda en DRAFT/READY hasta que OAuth esté vivo; al lanzar
// se crea un AdCampaign real y el externalId llega del API.

enum DraftStatus {
  DRAFT       // Borrador — wizard en curso
  READY       // Completo, esperando OAuth o botón "Publicar"
  LAUNCHED    // Publicado en plataforma
  PAUSED
  ARCHIVED
}

enum CampaignObjective {
  CONVERSIONS
  TRAFFIC
  REACH
  LEADS
  ENGAGEMENT
  MESSAGES
}

model CampaignDraft {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  name          String
  platform      AdPlatform        @default(META)
  objective     CampaignObjective @default(CONVERSIONS)
  status        DraftStatus       @default(DRAFT)
  step          Int               @default(1) // Paso actual del wizard (1-5)

  // Paso 2 — Audiencia
  targetCountry Country?
  ageMin        Int?              @default(18)
  ageMax        Int?              @default(55)
  gender        String?           @default("ALL") // ALL, MALE, FEMALE
  interests     String[]
  placements    String[]

  // Paso 3 — Creativo
  headline      String?
  primaryText   String?
  description   String?
  cta           String?           @default("BUY_NOW")
  imageUrl      String?
  videoUrl      String?
  landingUrl    String?

  // Paso 4 — Presupuesto
  dailyBudget   Float?
  totalBudget   Float?
  durationDays  Int?              @default(7)
  startDate     DateTime?

  // Resultado de lanzamiento
  launchedCampaignId String?      // -> AdCampaign.id cuando se publique
  externalId         String?      // ID en la plataforma tras OAuth launch
  launchNotes        String?      // Errores de launch, warnings

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────
// MEDIA BUYER IA (V16) — Recomendaciones accionables
// ─────────────────────────────────────────────────────────
// Analiza campañas activas y genera recomendaciones concretas
// (pausar/escalar/testear) con reasoning IA + métricas reales.

enum RecommendationType {
  PAUSE_CAMPAIGN        // ROAS bajo sostenido
  SCALE_BUDGET          // ROAS alto consistente
  REDUCE_BUDGET         // ROAS marginal, reduce en vez de pausar
  TEST_CREATIVE         // CTR bajo, fatiga de creativo
  TEST_AUDIENCE         // Frecuencia alta, audiencia saturada
  OPTIMIZE_BID          // CPC alto vs benchmark
  RESTART_CAMPAIGN      // Campaña pausada con potencial
  ADD_TRACKING          // Falta datos para decidir
}

enum RecommendationStatus {
  PENDING
  APPLIED
  DISMISSED
  EXPIRED
}

model CampaignRecommendation {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId    String?
  campaign      AdCampaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  accountId     String?
  account       AdAccount?          @relation(fields: [accountId], references: [id], onDelete: SetNull)

  type          RecommendationType
  status        RecommendationStatus @default(PENDING)
  priority      Int                 @default(50)        // 0 (baja) - 100 (crítica)

  title         String                                  // "Pausa 'Colágeno CO — Mujeres 25-45'"
  reasoning     String                                  // Por qué IA lo recomienda
  actionLabel   String                                  // "Pausar ahora" / "Subir +30%"
  suggestedValue Float?                                 // % o COP sugerido

  // Snapshot de métricas al generar
  roas          Float?
  spend         Float?
  revenue       Float?
  clicks        Int?
  conversions   Int?
  impressions   Int?
  confidence    Float?              @default(0.5)       // 0-1 certeza del modelo

  // Resultado
  appliedAt     DateTime?
  dismissedAt   DateTime?
  expiresAt     DateTime                                // Recomendaciones caducan en 72h

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId, status])
  @@index([campaignId])
}

// ─────────────────────────────────────────────────────────
// CREATIVO MAKER IA (V17) — Generador de creativos para ads
// ─────────────────────────────────────────────────────────
// Genera variantes de copy + imagen para cada producto, con
// múltiples ángulos (beneficio, dolor, urgencia, etc.).
// Cada creativo se puede lanzar directamente desde el Lanzador.

enum CreativeAngle {
  BENEFIT            // Destaca beneficio principal
  PAIN_POINT         // Dolor del cliente resuelto
  SOCIAL_PROOF       // Testimonios / números
  URGENCY            // Escasez / oferta
  LIFESTYLE          // Estilo de vida aspiracional
  TESTIMONIAL        // Caso real
  BEFORE_AFTER       // Transformación
  PROBLEM_SOLUTION   // Problema → producto
}

enum CreativeStatus {
  GENERATING
  READY
  FAILED
}

enum CreativeRatio {
  SQUARE             // 1:1 — feed Meta/TikTok
  PORTRAIT           // 4:5 — feed vertical
  STORY              // 9:16 — stories/reels
  LANDSCAPE          // 16:9 — YouTube/Display
}

model AdCreative {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     String
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  angle         CreativeAngle
  platform      AdPlatform      @default(META)
  ratio         CreativeRatio   @default(SQUARE)
  status        CreativeStatus  @default(READY)

  // Copy generado
  headline      String
  primaryText   String
  description   String?
  cta           String?         @default("BUY_NOW")
  hashtags      String[]

  // Imagen (URL Cloudinary o DALL-E)
  imageUrl      String?
  imagePrompt   String?         // Prompt usado para generar la imagen

  // Meta del creativo
  score         Int             @default(70)           // Predicción IA 0-100
  reasoning     String?                                 // Por qué IA eligió este ángulo
  isFavorite    Boolean         @default(false)
  timesUsed     Int             @default(0)            // Veces lanzado a Lanzador
  lastUsedAt    DateTime?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId, productId])
  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────
// OPTIMIZADOR DE TIENDA IA (V18) — Recomendaciones de catálogo
// ─────────────────────────────────────────────────────────
// Analiza el catálogo de productos Vitalcom + tienda Shopify del
// dropshipper + ventas + P&G y sugiere acciones concretas:
// qué productos destacar, pricing, copy de landing, cross-sell.
// Cada recomendación es accionable con 1 clic (aplicar/dismiss).

enum OptimizationType {
  HIGHLIGHT_PRODUCT    // Destacar producto ganador en home/tienda
  PRICING_ADJUSTMENT   // Subir/bajar precio de venta
  LANDING_COPY         // Mejorar copy de landing del producto
  CROSS_SELL           // Agregar cross-sell a producto X con Y
  PRODUCT_MIX          // Añadir/quitar producto del catálogo
  MARGIN_IMPROVEMENT   // Producto con margen bajo → optimizar
  RESTOCK_URGENT       // Stock bajo, restock antes que se agote
  REMOVE_UNDERPERFORMER // Producto sin ventas → remover
}

enum OptimizationStatus {
  PENDING
  APPLIED
  DISMISSED
  EXPIRED
}

model StoreOptimization {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?           @relation(fields: [productId], references: [id], onDelete: Cascade)

  type          OptimizationType
  status        OptimizationStatus @default(PENDING)
  priority      Int                @default(50)        // 0 (baja) - 100 (crítica)

  title         String                                  // "Destaca Colágeno Premium en tu home"
  reasoning     String                                  // Por qué IA lo recomienda
  actionLabel   String                                  // "Destacar", "Ajustar precio", "Ver copy"
  suggestedValue Float?                                 // Precio sugerido, % cambio, etc.
  suggestedText String?                                 // Copy nuevo, sugerencia textual
  suggestedData Json?                                   // Payload flexible (cross-sell targets, etc.)

  // Snapshot de métricas al generar
  salesLast30   Int?
  revenueLast30 Float?
  marginPct     Float?
  stockLevel    Int?
  conversionRate Float?
  confidence    Float?             @default(0.7)       // 0-1 certeza del modelo

  // Resultado
  appliedAt     DateTime?
  dismissedAt   DateTime?
  expiresAt     DateTime                                // Recomendaciones caducan en 14d

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId, status])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────
// IMPACT TRACKING IA (V21) — Mide el ROI real de cada
// recomendación IA aplicada: before/after snapshots + impact
// estimado con heurísticas calibradas + impact realizado
// cuando hay datos reales post-apply.
// ─────────────────────────────────────────────────────────

enum AppliedActionSource {
  MEDIA_BUYER
  STORE_OPTIMIZER
  CREATIVE_MAKER
}

model AppliedAction {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  source          AppliedActionSource
  actionType      String                                  // RecommendationType o OptimizationType
  sourceRecId     String?                                 // id de la rec original (CampaignRecommendation/StoreOptimization)

  // Contexto descriptivo
  title           String
  productId       String?
  campaignId      String?

  // Snapshots
  beforeSnapshot  Json                                    // { roas, spend, revenue, salesLast30, marginPct, stockLevel, etc. }
  afterSnapshot   Json?                                   // Se rellena en el recompute >=7d post-apply
  afterSnapshotAt DateTime?

  // Impacto estimado (calculado al aplicar, heurístico)
  estimatedImpactUsd  Float?                              // +$ ganado o -$ ahorrado en COP
  estimatedImpactKind String?                             // 'savings' | 'revenue' | 'margin' | 'retention'
  estimatedRationale  String?                             // Explicación en español de cómo se calculó

  // Impacto realizado (opcional — si hay datos reales post-apply)
  realizedImpactUsd   Float?
  realizedCalculatedAt DateTime?

  appliedAt       DateTime            @default(now())
  createdAt       DateTime            @default(now())

  @@index([userId, appliedAt])
  @@index([userId, source])
}

// ─────────────────────────────────────────────────────────
// BOTS AUTÓNOMOS (V23) — Ejecuciones background por Vercel Cron
// ─────────────────────────────────────────────────────────
// Cada BotRun registra una corrida: qué bot, cuándo, cuántos
// usuarios/items procesados, duración, errores. Permite
// debugging + métricas para el admin.

enum BotName {
  STOCK_BOT        // Alerta stock bajo por producto
  RESTOCK_BOT      // Notifica pedidos de reposición a admin
  ADS_BOT          // Monitorea ROAS/CPA y dispara recs
  INACTIVITY_BOT   // Reactiva dropshippers dormidos
  ONBOARDING_BOT   // Guía primeros 7 días del nuevo user
  SEO_BOT          // Genera meta tags automáticos (future)
  CONTENT_BOT      // Sugiere posts semanales (future)
  FULFILLMENT_BOT  // Sync tracking Dropi (future)
  PRECIO_BOT       // Ajusta precios sugeridos (future)
}

enum BotRunStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL   // Algunos usuarios OK, otros con error
}

model BotRun {
  id            String       @id @default(cuid())
  bot           BotName
  status        BotRunStatus @default(RUNNING)

  startedAt     DateTime     @default(now())
  finishedAt    DateTime?
  durationMs    Int?

  // Métricas de la corrida
  usersProcessed Int         @default(0)
  itemsAffected  Int         @default(0)
  notifsCreated  Int         @default(0)
  errors         Int         @default(0)

  // Output estructurado para debugging
  summary       String?
  errorLog      Json?
  triggeredBy   String?      @default("cron")  // 'cron' | 'manual' | userId

  @@index([bot, startedAt])
  @@index([status, startedAt])
}
