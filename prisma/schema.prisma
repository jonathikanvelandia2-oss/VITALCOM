  cloudinaryUrl   String?
  originalMime    String
  width           Int?
  height          Int?
  durationSec     Int?
  fileSizeBytes   Int?
  // Segmentación
  persona         String[]          @default([])
  country         String[]          @default([])
  language        String            @default("es_CO")
  // Metadata editorial
  title           String?
  caption         String?
  altText         String?
  assetTags       String[]          @default([])
  // Estado
  status          AssetStatus       @default(DRAFT)
  quality         AssetQualityScore @default(UNRATED)
  usedAsDefault   Boolean           @default(false)
  heroRank        Int?
  // Trazabilidad
  syncedBy        String?
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  videoCutsFromMe VideoClip[] @relation("SourceAsset")
  edits           AssetEdit[]

  @@index([productId, type])
  @@index([productId, status, heroRank])
