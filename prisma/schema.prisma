  painPoints      Json        @default("[]")
  howItWorks      Json        @default("[]")
  testimonials    Json        @default("[]")
  faq             Json        @default("[]")
  ugcClipIds      String[]    @default([])
  galleryAssetIds String[]    @default([])
  // Pricing
