// ═══════════════════════════════════════════════════════════
// V34 — Weekly Insights (reporte IA semanal por VITALCOMMER)
// ═══════════════════════════════════════════════════════════
// Un insight por usuario por semana (lunes-domingo).
// Unifica P&G + Health Score + alertas + recomendaciones en
// una narrativa accionable. El dropshipper abre UNA cosa en
// lugar de navegar 5 pantallas.
model WeeklyInsight {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Rango temporal (inclusive)
  weekStart       DateTime // Lunes 00:00:00 UTC
  weekEnd         DateTime // Domingo 23:59:59 UTC
  // Métricas P&G del período
  revenue         Float              @default(0)
  revenuePrev     Float              @default(0)
  revenueDeltaPct Float              @default(0)
  orderCount      Int                @default(0)
  orderCountPrev  Int                @default(0)
  netProfit       Float              @default(0)
  roas            Float              @default(0)
  breakEvenRoas   Float              @default(0)
  // Health Score snapshot
  healthScore     Int                @default(0)
  healthScorePrev Int?
  healthDelta     Int                @default(0)
  segment         UserHealthSegment?
  // Top producto de la semana
  topProductId    String?
  topProductName  String?
  topProductSales Int?
  // Narrativa generada (sin LLM por defecto, pero compatible)
  headline        String // "Subiste 23% vs la semana pasada"
  highlights      Json               @default("[]") // Array<{label, value, trend}>
  recommendations Json               @default("[]") // Array<{priority, title, action, href}>
  // Benchmarking anónimo (opcional, se llena si hay suficientes peers)
  tierAvgRevenue  Float?
  tierPercentile  Int? // 0-100 del usuario dentro de su segment
  // Estado
  generatedAt     DateTime           @default(now())
  readAt          DateTime?
  // Fuente (para auditar si vino de cron o de trigger manual)
  source          String             @default("manual")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@index([weekStart])
}

// ─────────────────────────────────────────────────────────
// V38 — CANALES VITALCOM (WhatsApp phonebook)
// ─────────────────────────────────────────────────────────
// Los canales oficiales de comunicación entre Vitalcom y su comunidad:
// números 1-a-1 por área, invites a grupos, canales de anuncios. Se
// sirven como deep links (wa.me) sin depender de Meta WABA — útil HOY
// mientras se aprueba la Business API.

enum ChannelType {
  STAFF_DM // 1-a-1 con un staff de un área (wa.me link con mensaje pre-llenado)
  COMMUNITY_GROUP // invite link a grupo de WhatsApp de la comunidad
  BROADCAST_LIST // lista de difusión (el user escribe para suscribirse)
  ANNOUNCEMENTS // WhatsApp Channels (read-only desde WA)
}

model VitalcomChannel {
  id             String      @id @default(cuid())
  type           ChannelType
  area           Area?
  label          String
  description    String?
  phone          String? // E.164 sin "+" (ej: 573001234567)
  inviteUrl      String? // para COMMUNITY_GROUP / ANNOUNCEMENTS
  defaultMessage String? // texto pre-llenado en wa.me?text=
  icon           String? // emoji o nombre lucide para el card
  country        Country?
  active         Boolean     @default(true)
  order          Int         @default(0)

  clicks ChannelClick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
  @@index([area, active])
  @@index([country, active])
}

model ChannelClick {
  id        String          @id @default(cuid())
  channelId String
  channel   VitalcomChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?           @relation(fields: [userId], references: [id])
  userAgent String?
  referrer  String?

  createdAt DateTime @default(now())

  @@index([channelId, createdAt])
  @@index([userId, createdAt])
}
