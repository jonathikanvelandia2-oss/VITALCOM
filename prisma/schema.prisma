// Vitalcom — Schema Prisma inicial
// Multi-rol + Multi-país (CO/EC/GT/CL)
// Ver CLAUDE.md sección "Schema de base de datos" para contexto completo

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum UserRole {
  SUPERADMIN
  ADMIN
  MANAGER_AREA
  EMPLOYEE
  COMMUNITY
  DROPSHIPPER
}

enum Country {
  CO
  EC
  GT
  CL
}

enum Area {
  DIRECCION // CEO — acceso total
  MARKETING // Campañas, contenido, comunidad
  COMERCIAL // Ventas, clientes, catálogo
  ADMINISTRATIVA // Operaciones, RRHH, procesos
  LOGISTICA // Stock, despachos, fulfillment Dropi
  CONTABILIDAD // Finanzas, facturación, liquidaciones
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  CANCELLED
  RETURNED
}

// V37 — Modo de fulfillment activo para un pedido.
// MANUAL: staff hace el envío con transportadora local + carga tracking a mano.
// DROPI/EFFI: provider externo crea el envío vía API (requiere credenciales).
// SHOPIFY_NATIVE: el vendedor Shopify gestiona el fulfillment en su tienda.
enum FulfillmentMode {
  MANUAL
  DROPI
  EFFI
  SHOPIFY_NATIVE
}

// V37 — Acciones registradas en el audit log de fulfillment.
enum FulfillmentAction {
  CREATED
  STATUS_CHANGED
  TRACKING_ASSIGNED
  CARRIER_ASSIGNED
  NOTE_ADDED
  MANUAL_DISPATCHED
  DROPI_DISPATCHED
  DELIVERED_CONFIRMED
  CANCELLED
  RETURNED
  REOPENED
}

enum OrderSource {
  DIRECT
  ZENDU
  COMMUNITY
  DROPSHIPPER
}

// ─── FINANZAS (P&L del dropshipper) ───
enum FinanceType {
  INGRESO
  EGRESO
}

enum FinanceCategory {
  VENTA // Ingreso por venta de orden
  COSTO_PRODUCTO // COGS (costo directo del producto)
  ENVIO // Costo de envío al cliente
  PUBLICIDAD // Meta, TikTok, Google ads
  COMISION_PLATAFORMA // Shopify, pasarela, Vitalcom
  DEVOLUCION // Reembolso o devolución
  EMPAQUE // Material de empaque
  OPERATIVO // Gastos operativos (internet, software)
  IMPUESTO // IVA, retenciones
  OTRO // Catch-all manual
}

enum FinanceSource {
  MANUAL // Registrado por el usuario
  ORDER_REVENUE // Auto-generado al entregar orden
  ORDER_COGS // Auto-generado al entregar orden
  ORDER_SHIPPING // Auto-generado al entregar orden
  ORDER_RETURN // Auto-generado al devolver orden
  AD_SPEND // Importado de Meta/TikTok/Google (Fase V2)
  SYSTEM // Otro auto
}

// ─────────────────────────────────────────────────────────
// USUARIOS Y AUTH
// ─────────────────────────────────────────────────────────

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  name     String?
  password String?
  role     UserRole @default(COMMUNITY)
  country  Country?
  area     Area?
  avatar   String?
  phone    String?
  whatsapp String?

  // Comunidad / gamificación
  level  Int     @default(1)
  points Int     @default(0)
  bio    String?

  // Estado
  active    Boolean  @default(true)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  posts                   Post[]
  comments                Comment[]
  inboxSent               InboxMessage[]           @relation("MessageSender")
  inboxReceived           InboxMessage[]           @relation("MessageReceiver")
  orders                  Order[]
  fulfilledOrders         Order[]                  @relation("OrderFulfiller")
  fulfillmentLogs         FulfillmentLog[]         @relation("FulfillmentActor")
  channelClicks           ChannelClick[]
  inboxAssigned           InboxThread[]            @relation("InboxAssignee")
  inboxResolved           InboxThread[]            @relation("InboxResolver")
  pricingCalcs            PricingCalculation[]
  workflows               WorkflowTemplate[]
  courseProgress          CourseProgress[]
  shopifyStores           ShopifyStore[]
  tasks                   Task[]
  meetings                Meeting[]
  uploadedDocs            Document[]               @relation("UploadedDocs")
  financeEntries          FinanceEntry[]
  notifications           Notification[]
  conversationsA          Conversation[]           @relation("ConversationUserA")
  conversationsB          Conversation[]           @relation("ConversationUserB")
  directMessages          DirectMessage[]          @relation("DirectMessageSender")
  workflowActivations     UserWorkflowActivation[]
  adAccounts              AdAccount[]
  campaignDrafts          CampaignDraft[]
  campaignRecommendations CampaignRecommendation[]
  adCreatives             AdCreative[]
  storeOptimizations      StoreOptimization[]
  appliedActions          AppliedAction[]
  goals                   UserGoal[]
  // V26 — Chat universal IA
  conversationThreads     ConversationThread[]
  userMemories            UserMemory[]
  escalationTickets       EscalationTicket[]       @relation("EscalationUser")
  escalationAssigned      EscalationTicket[]       @relation("EscalationAssignee")
  // V27 — WhatsApp Commerce
  whatsappAccounts        WhatsappAccount[]
  waWorkflows             WaWorkflow[]
  // V31 — Alertas proactivas
  proactiveAlerts         ProactiveAlert[]
  // V32 — Health Score
  healthScore             UserHealthScore?
  // V33 — Product Studio (dropshipper-owned landings)
  productLandings         ProductLanding[]
  // V34 — Weekly Insights proactivos
  weeklyInsights          WeeklyInsight[]
}

// ─────────────────────────────────────────────────────────
// CATÁLOGO
// ─────────────────────────────────────────────────────────

model Product {
  id                 String   @id @default(cuid())
  sku                String   @unique
  name               String
  slug               String   @unique
  description        String?
  category           String?
  subcategory        String?
  tags               String[]
  images             String[]
  // 8 niveles de precio Vitalcom (COP)
  precioPublico      Float // Precio consumidor final
  precioComunidad    Float // Precio miembros / dropshippers
  precioPrivado      Float // Precio VIP
  // Internos (solo admin)
  precioCosto        Float? // Costo de compra
  precioMayorProv    Float? // Mayor proveeduría
  precioMayorContado Float? // Mayor contado
  precioMayorCredito Float? // Mayor crédito
  precioMaquilla     Float? // Precio maquila

  // Datos extendidos del catálogo
  marca         String? // Marca del producto
  contenido     String? // "60U", "500ML", "1200G"
  presentacion  String? // Capsulas, Liquido, Polvos, etc.
  sabor         String? // Natural, Uva, Fresa, etc.
  bodega        String? // BIOBEL, VITALCOM
  codigoInterno String? // Código original de la base
  pertenece     String? // Dueño/influencer (para maquilas)
  weight        Float?
  dimensions    Json?
  active        Boolean @default(true)
  bestseller    Boolean @default(false)
  salesCount    Int     @default(0)

  // Landing page del producto
  videoUrl      String? // Video parallax (Cloudinary URL)
  ingredients   Json? // [{name, description, icon}]
  benefits      Json? // [{title, description, icon}]
  howToUse      String? // Instrucciones de uso
  testimonials  Json? // [{name, text, rating, photo}]
  landingConfig Json? // {heroText, ctaText, accentColor, sections[]}

  stock              Stock[]
  orderItems         OrderItem[]
  shopifySync        ProductSync[]
  campaignDrafts     CampaignDraft[]
  adCreatives        AdCreative[]
  storeOptimizations StoreOptimization[]
  // V33 — Product Studio
  productAssets      ProductAsset[]
  productLandings    ProductLanding[]
  ugcPackages        UgcPackage[]
  videoClips         VideoClip[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Stock {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  country   Country
  quantity  Int      @default(0)
  warehouse String?
  updatedAt DateTime @updatedAt

  @@unique([productId, country])
}

// ─────────────────────────────────────────────────────────
// PEDIDOS
// ─────────────────────────────────────────────────────────

model Order {
  id      String      @id @default(cuid())
  number  String      @unique
  userId  String?
  user    User?       @relation(fields: [userId], references: [id])
  source  OrderSource
  country Country
  status  OrderStatus @default(PENDING)

  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress String?

  items    OrderItem[]
  subtotal Float
  shipping Float
  total    Float

  trackingCode String?
  carrier      String?
  notes        String?
  externalRef  String?

  // V37 — Metadata de fulfillment
  fulfillmentMode FulfillmentMode @default(MANUAL)
  fulfilledById   String?
  fulfilledBy     User?           @relation("OrderFulfiller", fields: [fulfilledById], references: [id])
  fulfilledAt     DateTime?
  manualCost      Float? // Costo real pagado a transportadora (solo MANUAL)
  labelUrl        String? // URL guía/etiqueta (Dropi devuelve, manual opcional)

  logs FulfillmentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([externalRef])
  @@index([source, createdAt])
  @@index([country, createdAt])
  @@index([fulfillmentMode, status])
  @@index([fulfilledById, fulfilledAt])
}

// V37 — Audit trail de cada acción sobre un pedido.
// Cada cambio de estado, carga de tracking, o envío manual queda acá con
// actor + timestamp + metadata JSON para tener historia completa — clave
// para demostrar a Dropi/Effi que confiamos en nuestros flujos.
model FulfillmentLog {
  id         String            @id @default(cuid())
  orderId    String
  order      Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User              @relation("FulfillmentActor", fields: [actorId], references: [id])
  action     FulfillmentAction
  fromStatus OrderStatus?
  toStatus   OrderStatus?
  message    String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  total     Float

  @@index([productId])
  @@index([orderId])
}

// ─────────────────────────────────────────────────────────
// INBOX INTERNO (entre áreas)
// ─────────────────────────────────────────────────────────

model InboxThread {
  id       String  @id @default(cuid())
  subject  String
  area     Area
  priority String  @default("normal")
  resolved Boolean @default(false)

  // V39 — Asignación + SLA tracking
  assignedToId    String?
  assignedTo      User?     @relation("InboxAssignee", fields: [assignedToId], references: [id])
  firstResponseAt DateTime? // primera respuesta de staff — marca SLA met
  resolvedAt      DateTime?
  resolvedById    String?
  resolvedBy      User?     @relation("InboxResolver", fields: [resolvedById], references: [id])

  messages  InboxMessage[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([area, resolved, priority])
  @@index([assignedToId, resolved])
  @@index([resolved, createdAt])
}

model InboxMessage {
  id          String      @id @default(cuid())
  threadId    String
  thread      InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User        @relation("MessageSender", fields: [senderId], references: [id])
  receiverId  String?
  receiver    User?       @relation("MessageReceiver", fields: [receiverId], references: [id])
  body        String
  attachments String[]
  read        Boolean     @default(false)
  createdAt   DateTime    @default(now())
}

// ─────────────────────────────────────────────────────────
// COMUNIDAD (estilo Skool)
// ─────────────────────────────────────────────────────────

model Post {
  id        String     @id @default(cuid())
  authorId  String
  author    User       @relation(fields: [authorId], references: [id])
  title     String?
  body      String
  images    String[]
  category  String?
  pinned    Boolean    @default(false)
  likes     Int        @default(0)
  postLikes PostLike[]
  comments  Comment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([authorId, createdAt])
  @@index([category, createdAt])
  @@index([pinned, createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  parentId  String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())
}

model Course {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  description String?
  cover       String?
  level       String
  modules     Json
  published   Boolean          @default(false)
  order       Int              @default(0)
  progress    CourseProgress[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CourseProgress {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  courseId         String
  course           Course   @relation(fields: [courseId], references: [id])
  completedLessons String[]
  percentage       Int      @default(0)
  completed        Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  @@unique([userId, courseId])
}

// ─────────────────────────────────────────────────────────
// HERRAMIENTAS DE COMUNIDAD
// ─────────────────────────────────────────────────────────

model PricingCalculation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  productName String
  basePrice   Float
  shipping    Float
  margin      Float
  finalPrice  Float
  country     Country
  notes       String?
  createdAt   DateTime @default(now())
}

model WorkflowTemplate {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  slug        String?  @unique // Identificador legible para plantillas oficiales (ej: confirm-order)
  name        String
  description String?
  emoji       String?
  category    String
  target      String? // Audiencia del flujo (Nuevos pedidos, Leads, etc.)
  impact      String? // Etiqueta de resultado esperado
  steps       Json
  isPublic    Boolean  @default(false)
  uses        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activations UserWorkflowActivation[]
}

enum WorkflowStatus {
  ACTIVE
  PAUSED
}

model UserWorkflowActivation {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId   String
  template     WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  status       WorkflowStatus   @default(ACTIVE)
  executions   Int              @default(0)
  successCount Int              @default(0)
  lastRunAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, templateId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────
// INTEGRACIÓN SHOPIFY
// ─────────────────────────────────────────────────────────

model ShopifyStore {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  shopDomain     String        @unique // mi-tienda.myshopify.com
  storeName      String
  accessToken    String? // Token cifrado de Shopify API
  status         String        @default("not_connected")
  plan           String?
  productsCount  Int           @default(0)
  connectedAt    DateTime?
  lastSyncAt     DateTime?
  syncedProducts ProductSync[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model ProductSync {
  id               String       @id @default(cuid())
  shopifyStoreId   String
  store            ShopifyStore @relation(fields: [shopifyStoreId], references: [id], onDelete: Cascade)
  productId        String
  product          Product      @relation(fields: [productId], references: [id])
  shopifyProductId String
  shopifyVariantId String?
  sellingPrice     Float // Precio que el dropshipper puso en Shopify
  status           String       @default("active")
  soldTotal        Int          @default(0)
  lastSyncAt       DateTime     @default(now())
  createdAt        DateTime     @default(now())

  @@unique([shopifyStoreId, productId])
}

// ─────────────────────────────────────────────────────────
// TAREAS, REUNIONES, RECURSOS (Comunidad)
// ─────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  description String?
  status      String    @default("pending") // pending, in_progress, completed
  priority    String    @default("medium") // low, medium, high
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Meeting {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String?
  date        DateTime
  duration    Int      @default(60) // minutos
  link        String? // URL de meet/zoom
  type        String   @default("videocall") // videocall, presencial
  status      String   @default("scheduled") // scheduled, completed, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String // guias, plantillas, videos, ebooks
  type        String   @default("file") // file, link, video
  url         String // URL del archivo o enlace
  thumbnail   String?
  downloads   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id         String   @id @default(cuid())
  name       String
  folder     String   @default("general") // general, legal, marketing, logistica
  type       String // pdf, excel, doc, imagen
  url        String
  size       Int      @default(0) // bytes
  uploadedBy String
  uploader   User     @relation("UploadedDocs", fields: [uploadedBy], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// TOKENS DE SEGURIDAD
// ─────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────
// FINANZAS DEL DROPSHIPPER (P&L)
// ─────────────────────────────────────────────────────────
// Cada movimiento financiero del dropshipper. Combina entradas
// automáticas (ventas, COGS, envío) generadas al cerrar órdenes +
// entradas manuales (publicidad, empaque, operativo).
// El P&L se calcula agregando por periodo, tipo y categoría.

model FinanceEntry {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime        @default(now())
  type        FinanceType
  category    FinanceCategory
  amount      Float // Siempre positivo; el tipo indica signo
  currency    String          @default("COP")
  description String?
  source      FinanceSource   @default(MANUAL)

  // Referencias opcionales para rastrear origen
  relatedOrderId   String?
  relatedProductId String?
  metadata         Json? // Flexible: platformId, campaignId, adId (fase V2+)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, type, category])
  @@index([relatedOrderId])
}

// ─────────────────────────────────────────────────────────
// PUBLICIDAD (Meta / TikTok / Google Ads / Manual)
// ─────────────────────────────────────────────────────────
// Fase V2 del plan estratégico. Foundation que funciona con
// entrada manual hoy y queda lista para OAuth cuando lleguen
// credenciales.
//
// Cada AdSpendEntry genera automáticamente un FinanceEntry
// (EGRESO/PUBLICIDAD) para alimentar el P&G del dropshipper.

enum AdPlatform {
  META
  TIKTOK
  GOOGLE
  OTHER // Prensa, influencers, OOH — gastos no digitales
}

model AdAccount {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       AdPlatform
  accountId      String // ID externo (Meta/TikTok/Google) o label libre
  accountName    String?
  currency       String     @default("COP")
  connected      Boolean    @default(false) // false = manual, true = OAuth conectado
  accessToken    String? // Cuando llegue OAuth real
  refreshToken   String?
  tokenExpiresAt DateTime?
  lastSyncAt     DateTime?
  active         Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  campaigns       AdCampaign[]
  spendEntries    AdSpendEntry[]
  recommendations CampaignRecommendation[]

  @@unique([userId, platform, accountId])
  @@index([userId])
}

model AdCampaign {
  id         String    @id @default(cuid())
  accountId  String
  account    AdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalId String? // ID en la plataforma (cuando OAuth)
  name       String
  objective  String? // CONVERSIONS, TRAFFIC, AWARENESS, LEADS
  status     String    @default("ACTIVE") // ACTIVE, PAUSED, ENDED
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  spendEntries    AdSpendEntry[]
  recommendations CampaignRecommendation[]

  @@index([accountId])
}

model AdSpendEntry {
  id             String      @id @default(cuid())
  accountId      String
  account        AdAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaignId     String?
  campaign       AdCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  date           DateTime    @db.Date
  spend          Float // Gasto en la moneda de la cuenta
  impressions    Int?
  clicks         Int?
  conversions    Int?
  source         String      @default("MANUAL") // MANUAL, API_SYNC
  financeEntryId String?     @unique // Link al FinanceEntry auto-generado
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([accountId, date])
  @@index([campaignId, date])
}

// ─────────────────────────────────────────────────────────
// NOTIFICACIONES (in-app bell)
// ─────────────────────────────────────────────────────────
// Centraliza avisos al usuario: cambios de estado de pedido,
// menciones en comunidad, hilos de inbox asignados, etc.
// Para emails transaccionales, el envío se hace además desde
// el disparador del evento — este modelo es solo para el bell.

enum NotificationType {
  ORDER_STATUS // Pedido cambió de estado (DISPATCHED / DELIVERED / etc.)
  ORDER_NEW // Nuevo pedido recibido (staff)
  INBOX_MESSAGE // Mensaje nuevo en hilo del inbox
  INBOX_ASSIGNED // Hilo reasignado a tu área
  COMMUNITY_LIKE // Like a tu post/comentario
  COMMUNITY_REPLY // Respuesta a tu comentario
  COMMUNITY_DM // Mensaje directo 1:1 en comunidad
  STORE_CONNECTED // Tienda Shopify conectada
  AI_ACTION // V20 — Acción IA crítica del Command Center
  MORNING_BRIEF // V25 — Brief diario del día (8AM con top 3 + KPIs)
  WEEKLY_INSIGHT // V34 — Reporte semanal IA con recomendaciones
  SYSTEM // Anuncios de plataforma
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String? // Ruta interna para redirigir al hacer click
  meta      Json? // Payload adicional (orderNumber, threadId, etc.)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────
// CHAT 1:1 COMUNIDAD (mensajes directos entre miembros)
// ─────────────────────────────────────────────────────────
// Conversation es el "hilo" entre dos usuarios. Para garantizar
// unicidad, guardamos (userAId, userBId) en orden lexicográfico
// — eso hace el índice único determinístico sin importar quién inicia.

model Conversation {
  id            String          @id @default(cuid())
  userAId       String
  userA         User            @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId       String
  userB         User            @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime        @default(now())
  lastPreview   String? // Últimos ~120 chars para la lista
  unreadForA    Int             @default(0)
  unreadForB    Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  messages      DirectMessage[]

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  readAt         DateTime? // Timestamp cuando el otro participante lo leyó
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ─────────────────────────────────────────────────────────
// EVENTOS
// ─────────────────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  link        String? // URL de meet/zoom/teams
  type        String    @default("webinar") // webinar, live, meetup, workshop
  speaker     String?
  cover       String?
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────
// WIZARD LANZADOR DE CAMPAÑAS (V15 / V3 plan)
// ─────────────────────────────────────────────────────────
// CampaignDraft guarda el estado del wizard de 5 pasos.
// Queda en DRAFT/READY hasta que OAuth esté vivo; al lanzar
// se crea un AdCampaign real y el externalId llega del API.

enum DraftStatus {
  DRAFT // Borrador — wizard en curso
  READY // Completo, esperando OAuth o botón "Publicar"
  LAUNCHED // Publicado en plataforma
  PAUSED
  ARCHIVED
}

enum CampaignObjective {
  CONVERSIONS
  TRAFFIC
  REACH
  LEADS
  ENGAGEMENT
  MESSAGES
}

model CampaignDraft {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  name      String
  platform  AdPlatform        @default(META)
  objective CampaignObjective @default(CONVERSIONS)
  status    DraftStatus       @default(DRAFT)
  step      Int               @default(1) // Paso actual del wizard (1-5)

  // Paso 2 — Audiencia
  targetCountry Country?
  ageMin        Int?     @default(18)
  ageMax        Int?     @default(55)
  gender        String?  @default("ALL") // ALL, MALE, FEMALE
  interests     String[]
  placements    String[]

  // Paso 3 — Creativo
  headline    String?
  primaryText String?
  description String?
  cta         String? @default("BUY_NOW")
  imageUrl    String?
  videoUrl    String?
  landingUrl  String?

  // Paso 4 — Presupuesto
  dailyBudget  Float?
  totalBudget  Float?
  durationDays Int?      @default(7)
  startDate    DateTime?

  // Resultado de lanzamiento
  launchedCampaignId String? // -> AdCampaign.id cuando se publique
  externalId         String? // ID en la plataforma tras OAuth launch
  launchNotes        String? // Errores de launch, warnings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────
// MEDIA BUYER IA (V16) — Recomendaciones accionables
// ─────────────────────────────────────────────────────────
// Analiza campañas activas y genera recomendaciones concretas
// (pausar/escalar/testear) con reasoning IA + métricas reales.

enum RecommendationType {
  PAUSE_CAMPAIGN // ROAS bajo sostenido
  SCALE_BUDGET // ROAS alto consistente
  REDUCE_BUDGET // ROAS marginal, reduce en vez de pausar
  TEST_CREATIVE // CTR bajo, fatiga de creativo
  TEST_AUDIENCE // Frecuencia alta, audiencia saturada
  OPTIMIZE_BID // CPC alto vs benchmark
  RESTART_CAMPAIGN // Campaña pausada con potencial
  ADD_TRACKING // Falta datos para decidir
}

enum RecommendationStatus {
  PENDING
  APPLIED
  DISMISSED
  EXPIRED
}

model CampaignRecommendation {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String?
  campaign   AdCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  accountId  String?
  account    AdAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  type     RecommendationType
  status   RecommendationStatus @default(PENDING)
  priority Int                  @default(50) // 0 (baja) - 100 (crítica)

  title          String // "Pausa 'Colágeno CO — Mujeres 25-45'"
  reasoning      String // Por qué IA lo recomienda
  actionLabel    String // "Pausar ahora" / "Subir +30%"
  suggestedValue Float? // % o COP sugerido

  // Snapshot de métricas al generar
  roas        Float?
  spend       Float?
  revenue     Float?
  clicks      Int?
  conversions Int?
  impressions Int?
  confidence  Float? @default(0.5) // 0-1 certeza del modelo

  // Resultado
  appliedAt   DateTime?
  dismissedAt DateTime?
  expiresAt   DateTime // Recomendaciones caducan en 72h

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([campaignId])
}

// ─────────────────────────────────────────────────────────
// CREATIVO MAKER IA (V17) — Generador de creativos para ads
// ─────────────────────────────────────────────────────────
// Genera variantes de copy + imagen para cada producto, con
// múltiples ángulos (beneficio, dolor, urgencia, etc.).
// Cada creativo se puede lanzar directamente desde el Lanzador.

enum CreativeAngle {
  BENEFIT // Destaca beneficio principal
  PAIN_POINT // Dolor del cliente resuelto
  SOCIAL_PROOF // Testimonios / números
  URGENCY // Escasez / oferta
  LIFESTYLE // Estilo de vida aspiracional
  TESTIMONIAL // Caso real
  BEFORE_AFTER // Transformación
  PROBLEM_SOLUTION // Problema → producto
}

enum CreativeStatus {
  GENERATING
  READY
  FAILED
}

enum CreativeRatio {
  SQUARE // 1:1 — feed Meta/TikTok
  PORTRAIT // 4:5 — feed vertical
  STORY // 9:16 — stories/reels
  LANDSCAPE // 16:9 — YouTube/Display
}

model AdCreative {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  angle    CreativeAngle
  platform AdPlatform     @default(META)
  ratio    CreativeRatio  @default(SQUARE)
  status   CreativeStatus @default(READY)

  // Copy generado
  headline    String
  primaryText String
  description String?
  cta         String?  @default("BUY_NOW")
  hashtags    String[]

  // Imagen (URL Cloudinary o DALL-E)
  imageUrl    String?
  imagePrompt String? // Prompt usado para generar la imagen

  // Meta del creativo
  score      Int       @default(70) // Predicción IA 0-100
  reasoning  String? // Por qué IA eligió este ángulo
  isFavorite Boolean   @default(false)
  timesUsed  Int       @default(0) // Veces lanzado a Lanzador
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, productId])
  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────
// OPTIMIZADOR DE TIENDA IA (V18) — Recomendaciones de catálogo
// ─────────────────────────────────────────────────────────
// Analiza el catálogo de productos Vitalcom + tienda Shopify del
// dropshipper + ventas + P&G y sugiere acciones concretas:
// qué productos destacar, pricing, copy de landing, cross-sell.
// Cada recomendación es accionable con 1 clic (aplicar/dismiss).

enum OptimizationType {
  HIGHLIGHT_PRODUCT // Destacar producto ganador en home/tienda
  PRICING_ADJUSTMENT // Subir/bajar precio de venta
  LANDING_COPY // Mejorar copy de landing del producto
  CROSS_SELL // Agregar cross-sell a producto X con Y
  PRODUCT_MIX // Añadir/quitar producto del catálogo
  MARGIN_IMPROVEMENT // Producto con margen bajo → optimizar
  RESTOCK_URGENT // Stock bajo, restock antes que se agote
  REMOVE_UNDERPERFORMER // Producto sin ventas → remover
}

enum OptimizationStatus {
  PENDING
  APPLIED
  DISMISSED
  EXPIRED
}

model StoreOptimization {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  type     OptimizationType
  status   OptimizationStatus @default(PENDING)
  priority Int                @default(50) // 0 (baja) - 100 (crítica)

  title          String // "Destaca Colágeno Premium en tu home"
  reasoning      String // Por qué IA lo recomienda
  actionLabel    String // "Destacar", "Ajustar precio", "Ver copy"
  suggestedValue Float? // Precio sugerido, % cambio, etc.
  suggestedText  String? // Copy nuevo, sugerencia textual
  suggestedData  Json? // Payload flexible (cross-sell targets, etc.)

  // Snapshot de métricas al generar
  salesLast30    Int?
  revenueLast30  Float?
  marginPct      Float?
  stockLevel     Int?
  conversionRate Float?
  confidence     Float? @default(0.7) // 0-1 certeza del modelo

  // Resultado
  appliedAt   DateTime?
  dismissedAt DateTime?
  expiresAt   DateTime // Recomendaciones caducan en 14d

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────
// IMPACT TRACKING IA (V21) — Mide el ROI real de cada
// recomendación IA aplicada: before/after snapshots + impact
// estimado con heurísticas calibradas + impact realizado
// cuando hay datos reales post-apply.
// ─────────────────────────────────────────────────────────

enum AppliedActionSource {
  MEDIA_BUYER
  STORE_OPTIMIZER
  CREATIVE_MAKER
}

model AppliedAction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  source      AppliedActionSource
  actionType  String // RecommendationType o OptimizationType
  sourceRecId String? // id de la rec original (CampaignRecommendation/StoreOptimization)

  // Contexto descriptivo
  title      String
  productId  String?
  campaignId String?

  // Snapshots
  beforeSnapshot  Json // { roas, spend, revenue, salesLast30, marginPct, stockLevel, etc. }
  afterSnapshot   Json? // Se rellena en el recompute >=7d post-apply
  afterSnapshotAt DateTime?

  // Impacto estimado (calculado al aplicar, heurístico)
  estimatedImpactUsd  Float? // +$ ganado o -$ ahorrado en COP
  estimatedImpactKind String? // 'savings' | 'revenue' | 'margin' | 'retention'
  estimatedRationale  String? // Explicación en español de cómo se calculó

  // Impacto realizado (opcional — si hay datos reales post-apply)
  realizedImpactUsd    Float?
  realizedCalculatedAt DateTime?

  // V25 — Revert 1-clic
  revertedAt       DateTime?
  revertSideEffect String? // Descripción del revert ejecutado
  revertedBy       String? // userId que disparó el revert (default self)

  appliedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, appliedAt])
  @@index([userId, source])
  @@index([userId, revertedAt])
}

// ─────────────────────────────────────────────────────────
// BOTS AUTÓNOMOS (V23) — Ejecuciones background por Vercel Cron
// ─────────────────────────────────────────────────────────
// Cada BotRun registra una corrida: qué bot, cuándo, cuántos
// usuarios/items procesados, duración, errores. Permite
// debugging + métricas para el admin.

enum BotName {
  STOCK_BOT // Alerta stock bajo por producto
  RESTOCK_BOT // Notifica pedidos de reposición a admin
  ADS_BOT // Monitorea ROAS/CPA y dispara recs
  INACTIVITY_BOT // Reactiva dropshippers dormidos
  ONBOARDING_BOT // Guía primeros 7 días del nuevo user
  SEO_BOT // Genera meta tags automáticos (future)
  CONTENT_BOT // Sugiere posts semanales (future)
  FULFILLMENT_BOT // Sync tracking Dropi (future)
  PRECIO_BOT // Ajusta precios sugeridos (future)
  MORNING_BRIEF_BOT // V25 — Brief diario 8AM con top 3 acciones + KPI delta
}

enum BotRunStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL // Algunos usuarios OK, otros con error
}

model BotRun {
  id     String       @id @default(cuid())
  bot    BotName
  status BotRunStatus @default(RUNNING)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  durationMs Int?

  // Métricas de la corrida
  usersProcessed Int @default(0)
  itemsAffected  Int @default(0)
  notifsCreated  Int @default(0)
  errors         Int @default(0)

  // Output estructurado para debugging
  summary     String?
  errorLog    Json?
  triggeredBy String? @default("cron") // 'cron' | 'manual' | userId

  @@index([bot, startedAt])
  @@index([status, startedAt])
}

// ─────────────────────────────────────────────────────────
// METAS MENSUALES (V24) — Objetivos de revenue/orders por mes
// ─────────────────────────────────────────────────────────
// El dropshipper define su meta mensual. El Command Center
// re-prioriza acciones IA según la brecha entre progreso actual
// y meta. Celebración automática al alcanzar 100%.

enum GoalStatus {
  ACTIVE
  ACHIEVED
  MISSED // Mes cerrado sin alcanzar
  ARCHIVED
}

model UserGoal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Ventana mensual (primer día del mes en UTC)
  year  Int
  month Int // 1-12

  // Metas
  targetRevenue  Float // COP
  targetOrders   Int? // opcional
  targetMargin   Float? // % opcional
  stretchRevenue Float? // meta "estiramiento"

  // Tracking del cierre (se llena al finalizar el mes)
  achievedRevenue Float?
  achievedOrders  Int?
  achievedMargin  Float?
  status          GoalStatus @default(ACTIVE)
  achievedAt      DateTime?

  // Celebración (para evitar re-disparar)
  celebrationSent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────
// V26 — CHAT UNIVERSAL IA (Orchestrator + Memoria + Escalación)
// ─────────────────────────────────────────────────────────
// Entrada unificada al sistema IA. El orchestrator clasifica la
// intención, construye contexto (persona + P&G + memoria), llama
// al LLM apropiado, y escala a humano si la confianza es baja.
//
// Los 9 agentes existentes (VITA, MentorFinanciero, BlueprintAnalyst,
// CEOAdvisor, MarketingGenerator, CreativeCopyWriter, MediaBuyer,
// CreativoMaker, OptimizadorTienda, SoporteIA) siguen funcionando
// como páginas dedicadas — este sistema añade una capa de entrada
// universal por chat + ruteo inteligente.

enum ChatAgent {
  VITA // Default / orquestador general
  MENTOR_FINANCIERO
  BLUEPRINT_ANALYST
  CEO_ADVISOR
  MEDIA_BUYER
  CREATIVO_MAKER
  OPTIMIZADOR_TIENDA
  SOPORTE_IA
  ESCALATE_HUMAN // Nunca responde, solo marca escalación
}

enum ChatChannel {
  WEB
  WHATSAPP
  PUSH
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model ConversationThread {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentName ChatAgent   @default(VITA)
  channel   ChatChannel @default(WEB)
  title     String? // Generado desde el primer mensaje

  // Escalación
  escalatedToArea Area?
  escalatedAt     DateTime?

  // Resumen del thread (actualizado async post-cierre)
  lastMessageAt DateTime @default(now())
  messageCount  Int      @default(0)

  messages          ConversationMessage[]
  escalationTickets EscalationTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, lastMessageAt])
  @@index([userId, agentName])
}

model ConversationMessage {
  id       String             @id @default(cuid())
  threadId String
  thread   ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role     MessageRole
  content  String

  // Metadata del LLM (solo en ASSISTANT)
  model      String? // gpt-4o-mini | cache | rules | human | escalation
  confidence Float? // 0..1
  costUsd    Float?
  latencyMs  Int?
  source     String? // llm | cache | rules | human

  // Attachments multimodal (V27)
  attachments Json? // [{ mediaUploadId, type }]

  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}

enum MemoryKind {
  PREFERENCE // Estilo de comunicación, horarios
  FACT // Datos objetivos del negocio
  GOAL // Metas explícitas del usuario
  PAIN_POINT // Frustraciones recurrentes
  SUCCESS // Algo que le funcionó
  WARNING // Algo a evitar en su contexto
}

// Memoria estructurada del usuario. En V28 se añade embedding como Json
// (array de 1536 floats de text-embedding-3-small) para búsqueda semántica
// in-memory sin necesidad de pgvector. Si embedding es null, fallback a
// filtro por keyword+importance (modo V26).
model UserMemory {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind           MemoryKind
  content        String // Max ~280 chars idealmente
  embedding      Json? // V28 — array 1536 floats, opcional
  importance     Float      @default(0.5) // 0..1 — decae con el tiempo
  sourceThreadId String? // Thread origen (no FK para no bloquear cleanup)
  expiresAt      DateTime? // Null = permanente
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId, kind])
  @@index([userId, importance])
  @@index([expiresAt])
}

enum EscalationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum EscalationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Ticket de escalación a humano. Cada thread puede generar múltiples
// (aunque lo usual es 1). El humano lo toma desde /admin/escalations.
model EscalationTicket {
  id       String             @id @default(cuid())
  userId   String
  user     User               @relation("EscalationUser", fields: [userId], references: [id], onDelete: Cascade)
  threadId String
  thread   ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  fromAgent ChatAgent
  toArea    Area
  priority  EscalationPriority @default(MEDIUM)
  status    EscalationStatus   @default(OPEN)

  reason        String // Por qué IA escaló
  summary       String? // Resumen del thread generado por IA
  draftResponse String? // Respuesta draft del LLM (low-confidence)

  // Asignación + resolución
  assignedTo  String?
  assignee    User?     @relation("EscalationAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  assignedAt  DateTime?
  resolvedAt  DateTime?
  resolution  String? // Qué hizo el humano
  replyToUser String? // Mensaje final enviado al usuario

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, priority])
  @@index([toArea, status])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────
// V26 — SEMANTIC CACHE (capa 1 — hash exacto con userId)
// ─────────────────────────────────────────────────────────
// En V26 solo usamos hash exacto por (userId, agentName, query normalizada)
// — esto evita fugas entre usuarios y cachea respuestas idénticas.
// En V28 se agregará columna embedding vector(1536) + match semántico >0.92.

model SemanticCache {
  id          String    @id @default(cuid())
  queryHash   String    @unique // sha256 de "userId:agentName:normalized"
  userId      String? // Opcional — null = respuesta "canónica" compartible
  agentName   ChatAgent
  query       String // Query original (para debugging)
  embedding   Json? // V28 — array de floats opcional para match semántico cross-user (solo canónicas)
  isCanonical Boolean   @default(false) // V28 — true = respuesta sin datos personales, matcheable semántico entre usuarios
  response    String
  hits        Int       @default(0)
  lastHitAt   DateTime  @default(now())
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([agentName, expiresAt])
  @@index([userId])
  @@index([agentName, isCanonical, expiresAt])
}

// ─────────────────────────────────────────────────────────
// V27 — WHATSAPP COMMERCE + WORKFLOW ENGINE
// ─────────────────────────────────────────────────────────
// Foundation para operar WhatsApp Business Cloud API con
// workflows adaptativos (mejora Lucidbot). En V27 funciona en
// MODO MOCK (sin credenciales externas) — guarda mensajes en
// BD y el engine ejecuta todo el pipeline igual. Cuando lleguen
// credenciales CEO (Meta Business App + WABA + tokens), solo se
// cambia WHATSAPP_MOCK_MODE=false y el cliente llama la API real.

enum WaAccountQuality {
  GREEN
  YELLOW
  RED
  UNKNOWN
}

enum WaAccountTier {
  TIER_250
  TIER_1K
  TIER_10K
  TIER_100K
  UNLIMITED
}

enum WaMessageDirection {
  INBOUND
  OUTBOUND
}

enum WaMessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
  INTERACTIVE
  BUTTON
  LOCATION
  CONTACTS
  STICKER
}

enum WaMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  BLOCKED
}

enum WaTemplateCategory {
  UTILITY
  MARKETING
  AUTHENTICATION
}

enum WaTemplateStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  DISABLED
}

enum WaWorkflowStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum WaWorkflowTrigger {
  ORDER_CREATED
  MESSAGE_RECEIVED
  NO_RESPONSE
  SCHEDULE
  WEBHOOK
  MANUAL
}

enum WaOrderConfirmStatus {
  PENDING
  CONFIRMED_HOT // Botón caliente Shopify
  CONFIRMED_BOT // Confirmó por mensaje al bot
  CONFIRMED_AGENT // Confirmó por agente humano
  NOT_CONFIRMED // Timeout total
  CANCELLED
}

// Cuenta WhatsApp Business Cloud API — un VITALCOMMER puede tener N
model WhatsappAccount {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String // "Caramela Beauty"
  phoneNumberId      String           @unique // Meta phone number ID
  wabaId             String // WhatsApp Business Account ID
  displayPhone       String // "+57 300 123 4567"
  accessToken        String // Cifrado en app (V28)
  webhookVerifyToken String
  // Estado Meta
  quality            WaAccountQuality @default(UNKNOWN)
  messagingLimit     WaAccountTier?
  isActive           Boolean          @default(true)
  // Branding
  logoUrl            String?
  businessName       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  templates         WhatsappTemplate[]
  conversations     WhatsappConversation[]
  contacts          WhatsappContact[]
  workflows         WaWorkflow[]
  WhatsappBroadcast WhatsappBroadcast[]

  @@index([userId])
}

// Plantillas aprobadas por Meta
model WhatsappTemplate {
  id                 String             @id @default(cuid())
  accountId          String
  account            WhatsappAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metaName           String // "confirmacion"
  category           WaTemplateCategory
  language           String // "es_CO", "en"
  // Contenido
  headerType         String? // NONE | TEXT | IMAGE | VIDEO | DOCUMENT
  headerContent      String?
  bodyText           String
  footerText         String?
  buttons            Json? // [{type, text, url?}]
  variables          Json?
  // Estado Meta
  status             WaTemplateStatus   @default(DRAFT)
  metaTemplateId     String?
  rejectionReason    String?
  // Performance
  timesSent          Int                @default(0)
  timesOpened        Int                @default(0)
  timesClicked       Int                @default(0)
  timesBlocked       Int                @default(0)
  // Fallback chain — mejora Lucidbot
  fallbackTemplateId String?
  // Propósito lógico
  purpose            String // confirmation | retry | abandoned_cart | etc
  // V29 — A/B testing: templates con el mismo variantGroup compiten por split aleatorio ponderado
  variantGroup       String? // ej "confirmacion_co_2026q2"
  weight             Float              @default(1) // peso en el split (mayor = más tráfico)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  broadcastRecipients WhatsappBroadcastRecipient[]

  @@unique([accountId, metaName, language])
  @@index([accountId, purpose])
  @@index([accountId, variantGroup])
}

// ─────────────────────────────────────────────────────────
// V29 — BROADCAST SEGMENTADO
// ─────────────────────────────────────────────────────────
// Envío de plantilla a un grupo filtrado de contactos.
// Respeta opt-out (WhatsappContact.isOptedIn=false).

enum WaBroadcastStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum WaBroadcastRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

model WhatsappBroadcast {
  id              String            @id @default(cuid())
  accountId       String
  account         WhatsappAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name            String
  templateName    String
  languageCode    String            @default("es_CO")
  bodyVariables   Json?
  headerVariables Json?
  // Segmentación — filtros evaluados al disparar
  segmentFilter   Json // {segment?, tags?, country?, minLtv?, excludeTags?}
  // Estado
  status          WaBroadcastStatus @default(DRAFT)
  scheduledFor    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  // Métricas agregadas
  totalRecipients Int               @default(0)
  sentCount       Int               @default(0)
  failedCount     Int               @default(0)
  optedOutCount   Int               @default(0)
  variantGroup    String? // si es A/B, reporta stats por variante
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  recipients WhatsappBroadcastRecipient[]

  @@index([accountId, status])
  @@index([scheduledFor])
}

model WhatsappBroadcastRecipient {
  id            String                     @id @default(cuid())
  broadcastId   String
  broadcast     WhatsappBroadcast          @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contactId     String
  contact       WhatsappContact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phoneE164     String
  templateId    String?
  template      WhatsappTemplate?          @relation(fields: [templateId], references: [id], onDelete: SetNull)
  variantKey    String? // "A" | "B" | ...
  status        WaBroadcastRecipientStatus @default(PENDING)
  metaMessageId String?
  failureReason String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  createdAt     DateTime                   @default(now())

  @@index([broadcastId, status])
  @@index([contactId])
  @@index([variantKey])
}

// Contacto — perfil extendido del comprador
model WhatsappContact {
  id                  String          @id @default(cuid())
  accountId           String
  account             WhatsappAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  phoneE164           String // +573001234567
  firstName           String?
  lastName            String?
  email               String?
  shippingAddress     String?
  shippingCity        String?
  shippingState       String?
  shippingCountry     String? // CO | EC | GT | CL
  // Scoring
  lifetimeValue       Float           @default(0)
  orderCount          Int             @default(0)
  confirmationRate    Float? // 0..1
  cancellationRate    Float?
  deliverySuccessRate Float?
  avgResponseMinutes  Int?
  // Tags como JSON con metadata
  tags                Json            @default("[]")
  segment             String? // hot_lead | repeat_buyer | at_risk | cancelador | vip
  // Estado
  isOptedIn           Boolean         @default(true)
  optedOutAt          DateTime?
  optOutSource        String? // "stop_keyword" | "admin" | "bounce"
  lastInteractionAt   DateTime?
  lastConversationId  String?
  // Ventana 24h (regla WhatsApp Business)
  lastUserMessageAt   DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  conversations       WhatsappConversation[]
  orders              WhatsappOrderLink[]
  broadcastRecipients WhatsappBroadcastRecipient[]

  @@unique([accountId, phoneE164])
  @@index([accountId, segment])
  @@index([accountId, isOptedIn])
  @@index([accountId, shippingCountry])
}

model WhatsappConversation {
  id                 String          @id @default(cuid())
  accountId          String
  account            WhatsappAccount @relation(fields: [accountId], references: [id])
  contactId          String
  contact            WhatsappContact @relation(fields: [contactId], references: [id])
  // Puente al chat universal V26
  aiThreadId         String?
  metaConversationId String?
  status             String          @default("active") // active | archived | blocked
  windowExpiresAt    DateTime?
  orderId            String?
  // Métricas
  messagesIn         Int             @default(0)
  messagesOut        Int             @default(0)
  costUsd            Float           @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  messages WhatsappMessage[]

  @@index([accountId, status])
  @@index([contactId])
}

model WhatsappMessage {
  id                String               @id @default(cuid())
  conversationId    String
  conversation      WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  metaMessageId     String?              @unique
  direction         WaMessageDirection
  type              WaMessageType
  content           String?
  mediaUrl          String?
  mediaUploadId     String? // Link a MediaUpload multimodal (V28)
  templateId        String?
  templateVariables Json?
  status            WaMessageStatus      @default(QUEUED)
  failureReason     String?
  // Interacción
  buttonReplyId     String?
  buttonReplyTitle  String?
  // Meta-contexto IA
  intent            String? // confirm | cancel | question | ...
  sentiment         String? // positive | neutral | negative | frustrated
  // Timing
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  createdAt         DateTime             @default(now())

  @@index([conversationId, createdAt])
  @@index([metaMessageId])
}

// Workflow adaptativo con IA — motor Vitalcom
// Prefijo Wa para evitar colisión con WorkflowTemplate (Luzitbot chatflows)
model WaWorkflow {
  id                 String            @id @default(cuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId          String?
  account            WhatsappAccount?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  // Identidad
  name               String
  purpose            String // order_confirmation | abandoned_cart | delivery | reactivation
  isActive           Boolean           @default(true)
  // Trigger
  triggerType        WaWorkflowTrigger
  triggerConfig      Json
  // Steps — JSON con nodos
  steps              Json // WorkflowStep[]
  // IA
  useAiAdaptation    Boolean           @default(true)
  usePersonalization Boolean           @default(true)
  // Métricas
  timesExecuted      Int               @default(0)
  successCount       Int               @default(0)
  failCount          Int               @default(0)
  avgDurationMin     Float?
  confidenceScore    Float             @default(0.5)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  executions WaExecution[]

  @@index([userId, isActive])
  @@index([accountId, purpose])
}

model WaExecution {
  id             String           @id @default(cuid())
  workflowId     String
  workflow       WaWorkflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contactId      String?
  conversationId String?
  orderId        String?
  // Estado
  status         WaWorkflowStatus @default(RUNNING)
  currentStepId  String?
  context        Json             @default("{}")
  // Outcome
  outcomeType    String? // positive | negative | neutral | timeout
  outcomeDetail  String?
  // Timing
  startedAt      DateTime         @default(now())
  completedAt    DateTime?
  nextWakeupAt   DateTime?

  stepRuns WaStepRun[]

  @@index([workflowId, status])
  @@index([nextWakeupAt])
  @@index([contactId])
  @@index([orderId])
}

model WaStepRun {
  id           String      @id @default(cuid())
  executionId  String
  execution    WaExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepId       String
  stepType     String
  status       String // success | failed | skipped
  input        Json?
  output       Json?
  startedAt    DateTime    @default(now())
  finishedAt   DateTime?
  durationMs   Int?
  errorMessage String?

  @@index([executionId])
}

// Link pedido ↔ contacto WhatsApp (con tracking de confirmación)
model WhatsappOrderLink {
  id                  String               @id @default(cuid())
  orderId             String               @unique
  contactId           String
  contact             WhatsappContact      @relation(fields: [contactId], references: [id])
  confirmationStatus  WaOrderConfirmStatus @default(PENDING)
  confirmedAt         DateTime?
  confirmationChannel String? // hot_button | bot_reply | bot_after_retries | human_agent
  // Fulfillment
  fulfillmentId       String?
  trackingNumber      String?
  carrier             String?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  returnedAt          DateTime?
  returnReason        String?
