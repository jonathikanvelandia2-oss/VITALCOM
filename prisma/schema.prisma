  @@index([contactId])
  @@index([confirmationStatus])
}

model AbandonedCart {
  id                   String    @id @default(cuid())
  accountId            String
  contactId            String?
  phoneE164            String?
  firstName            String?
  // Datos del carrito
  shopifyCartId        String?   @unique
  checkoutUrl          String
  items                Json // [{productId, name, quantity, price}]
  totalValue           Float
  currency             String
  status               String    @default("abandoned") // abandoned | recovered | expired
  recoveredAt          DateTime?
  // Acciones
  recoveryMessagesSent Int       @default(0)
  lastMessageAt        DateTime?
  abandonedAt          DateTime  @default(now())
  expiresAt            DateTime

  @@index([accountId, status])
  @@index([phoneE164])
}

// Hot-button del snippet Shopify (tracking de clicks + A/B test)
model HotButtonEvent {
  id          String   @id @default(cuid())
  shopDomain  String
  orderId     String?
  orderNumber String?
  phoneE164   String?
  // Tracking
  eventType   String // view | click | dismiss
  variant     String? // A | B (para A/B test del copy)
  userAgent   String?
  referrer    String?
  createdAt   DateTime @default(now())

  @@index([shopDomain, createdAt])
  @@index([orderId])
}

// Dedup de webhooks externos (Shopify/Effi) por eventId
model WebhookEvent {
  id          String   @id @default(cuid())
  source      String // shopify | effi | meta
  externalId  String // x-shopify-webhook-id, effi event_id, meta message_id
  topic       String? // orders/create, checkouts/update, guide_generated
  processedAt DateTime @default(now())
  payloadSha  String? // sha256 del body para verificación

  @@unique([source, externalId])
  @@index([source, processedAt])
}

// ═══════════════════════════════════════════════════════════
// V31 — Alertas proactivas para el dropshipper
// ═══════════════════════════════════════════════════════════
// Cron horario evalúa reglas activas de cada dropshipper y dispara
// notificaciones in-app + WhatsApp cuando se cumple la condición.
// Cooldown para evitar spam · log de entregas para debug.

enum ProactiveAlertType {
  STOCK_LOW // Stock de un producto cayó bajo umbral en el país del dropshipper
  ORDER_DISPATCHED // Uno de sus pedidos pasó a DISPATCHED
  ORDER_DELIVERED // Uno de sus pedidos pasó a DELIVERED
  DAILY_SUMMARY // Resumen del día (pedidos + revenue + P&G)
  ROAS_DROP // ROAS cayó bajo umbral
}

enum ProactiveAlertChannel {
  IN_APP // Solo Notification (bell icon)
  WHATSAPP // Solo WhatsApp
  BOTH // Los dos
}

model ProactiveAlert {
  id              String                @id @default(cuid())
  userId          String
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            ProactiveAlertType
  channel         ProactiveAlertChannel @default(IN_APP)
  enabled         Boolean               @default(true)
  // Config JSON depende del type:
  //  STOCK_LOW       → { threshold: number, productSkus?: string[] }
  //  ORDER_DISPATCHED → { includeTracking: boolean }
  //  DAILY_SUMMARY   → { hour: number (0-23 local) }
  //  ROAS_DROP       → { threshold: number, windowHours: number }
  config          Json                  @default("{}")
  cooldownMinutes Int                   @default(1440) // 24h default
  lastTriggeredAt DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  logs ProactiveAlertLog[]

  @@index([userId, type, enabled])
}

model ProactiveAlertLog {
  id           String                @id @default(cuid())
  alertId      String
  alert        ProactiveAlert        @relation(fields: [alertId], references: [id], onDelete: Cascade)
  // Contexto del disparo
  payload      Json // snapshot de los datos que motivaron el alert
  // Envío
  deliveredAt  DateTime              @default(now())
  channel      ProactiveAlertChannel
  whatsappSent Boolean               @default(false)
  notifyId     String? // id de Notification si se creó
  errorMessage String?

  @@index([alertId, deliveredAt])
}

// ═══════════════════════════════════════════════════════════
// V32 — Health Score del VITALCOMMER
// ═══════════════════════════════════════════════════════════
// Snapshot actual del estado de salud de cada miembro de la
// comunidad. Cron diario recalcula. El delta permite trend y
// disparar flujos de retención cuando cae de ACTIVE → AT_RISK.

enum UserHealthSegment {
  NEW // Registrado hace < 7 días (no se califica aún)
  ACTIVE // Score >= 60
  AT_RISK // Score 30-59
  CHURNED // Score < 30
}

model UserHealthScore {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Score actual 0-100
  score                  Int                @default(0)
  segment                UserHealthSegment  @default(NEW)
  // Desglose por factor (JSON con nombres de factor + puntos)
  breakdown              Json               @default("{}")
  // Trend
  previousScore          Int?
  scoreDelta             Int?
  previousSegment        UserHealthSegment?
  // Metadatos
  computedAt             DateTime           @default(now())
  // Retención: último flujo disparado
  lastRetentionTriggerAt DateTime?

  @@index([segment, computedAt])
  @@index([score])
}

// ═══════════════════════════════════════════════════════════
// V33 — Product Studio
// ═══════════════════════════════════════════════════════════
// Catálogo enriquecido con assets reales (fotos/videos/PDFs)
// sincronizados desde Drive, editados con IA, y presentados
// en landings de alta conversión con 4 agentes creativos.

enum AssetType {
  HERO
  GALLERY
  LIFESTYLE
  PRODUCT_ONLY
  PACK_SHOT
  MOCKUP
  REVIEW_PHOTO
  BEFORE_AFTER
  UGC_CLIP
  REEL_MASTER
  VIDEO_CUT
  LANDING_HERO
  EBOOK
  BRAND_MANUAL
  CERTIFICATE
  INGREDIENT_INFO
}

enum SalesAngle {
  PAIN
  ASPIRATION
  SOCIAL_PROOF
  EXPERT
  TESTIMONIAL
  TRANSFORMATION
  FEAR
  CURIOSITY
  EDUCATIONAL
  SCARCITY
  PRICE_ANCHOR
}

enum AssetFormat {
  SQUARE_1x1
  PORTRAIT_4x5
  STORY_9x16
  LANDSCAPE_16x9
  BANNER_3x1
  A4_PORTRAIT
  FREEFORM
}

enum AssetStatus {
  DRAFT
  APPROVED
  FEATURED
  ARCHIVED
  REJECTED
}

enum AssetQualityScore {
  A_PREMIUM
  B_STANDARD
  C_ACCEPTABLE
  UNRATED
}

model ProductAsset {
  id              String            @id @default(cuid())
  productId       String
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Origen Drive (o edit)
