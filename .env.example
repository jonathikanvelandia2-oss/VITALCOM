# ──────────────────────────────────────────
# VITALCOM — variables de entorno
# Copiar a .env.local y completar
# ──────────────────────────────────────────

# Base de datos (Supabase Postgres - usar pooler)
DATABASE_URL="postgresql://postgres.xxx:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxx:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# NextAuth
NEXTAUTH_SECRET="generar-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# ── Dropi (logística multi-país) ───────────────────────
# API key para crear envíos desde /api/orders/[id]/fulfill.
# Sin ella, la UI de despachos cae a modo manual (ingresar tracking a mano).
# Solicitar a: https://app.dropi.co → Integraciones → API
DROPI_API_KEY=""
DROPI_API_URL="https://api.dropi.co"
# Secreto HMAC para verificar webhooks de tracking de Dropi.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Configurar el MISMO valor en el panel Dropi → Webhooks → Secret.
DROPI_WEBHOOK_SECRET=""

# ── Shopify OAuth (V4) ─────────────────────────────────
# Obtener desde partners.shopify.com → Apps → "Create app"
# Tipo de distribución sugerido: Custom distribution (gratis, sin review).
# Redirect URL a configurar en Partners:
#   https://vitalcom.vercel.app/api/shopify/callback
# Si se omite CLIENT_ID/SECRET, /api/shopify/install responde 503 sin romper nada.
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""
SHOPIFY_API_VERSION="2025-01"

# Encryption key para cifrar access_tokens de Shopify en reposo (AES-256-GCM).
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRÍTICO en producción. En dev: si falta, los tokens se guardan en base64 (warning).
VITALCOM_ENCRYPTION_KEY=""

# Resend (emails transaccionales: welcome, reset password, order confirm)
# Gratis hasta 3.000 emails/mes en el plan free de Resend.
# Si se omite, los emails se skipean silenciosamente (no bloquea el flujo).
RESEND_API_KEY="re_..."
EMAIL_FROM="Vitalcom <noreply@vitalcom.co>"

# ── Fase 2 ──
# Pagos LATAM
WOMPI_PUBLIC_KEY=""
WOMPI_PRIVATE_KEY=""
MERCADOPAGO_ACCESS_TOKEN=""
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Zendu Marketplace (Vitalcom como proveedor)
ZENDU_API_URL=""
ZENDU_API_KEY=""

# WhatsApp Business
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Vitalcom"

# ── Middleware dev bypass ──────────────────────────────
# CRÍTICO: NO poner en producción. Solo para desarrollo local.
# Con "true" el middleware deja pasar todo sin verificar sesión.
# En producción (Vercel) debe estar AUSENTE o "false".
VITALCOM_DEV_BYPASS="false"
# Alternativa para QA: NEXT_PUBLIC_TESTING_MODE="true"
